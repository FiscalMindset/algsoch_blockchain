# Sepolia Testnet RPC URL
# Get a free API key from Infura (https://www.infura.io) or Alchemy (https://www.alchemy.com)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Deployer private key (the account that will deploy the contract)
# IMPORTANT: This key must have Sepolia ETH for gas. Get free ETH from a faucet below.
# DO NOT use a private key with real mainnet funds.
DEPLOYER_PRIVATE_KEY=0x...